# Tudo Configuration

## Database
DB_USER=tudo
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=tudo

## JWT
JWT_SECRET=change-me-to-a-very-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

## Registration
# Set to "false" to disable new user registration after initial setup
REGISTRATION_OPEN=true

## TLS / HTTPS (optional — Caddy can use Let's Encrypt)
# Point to your certificate files inside the container (mounted via TUDO_CERTS_DIR)
# Leave empty for automatic Let's Encrypt
TLS_CERT_PATH=
TLS_KEY_PATH=

## Domain (for Let's Encrypt)
DOMAIN=tudo.example.com

## Docker image version
TUDO_VERSION=latest

## Host certificates directory (volume mount path on host)
TUDO_CERTS_DIR=./certs
