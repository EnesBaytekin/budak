# Budak Configuration
# Copy to .env in the same directory as the binary.

## Server
PORT=8080

## Database (SQLite)
DB_PATH=budak.db

## JWT (required)
# Generate a secret with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-very-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

## Registration
REGISTRATION_OPEN=true

## Whitelist (optional)
# Restrict registration to specific usernames only.
# Create whitelist.txt (one username per line) next to the binary.
# WHITELIST_ENABLED=true
# WHITELIST_FILE=whitelist.txt

## CORS (optional)
# Allowed origins for browser CORS. Defaults to * (allow all).
# CORS_ORIGINS=https://app.example.com
