# Budak Configuration

## Database
DB_USER=budak
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=budak

## JWT
JWT_SECRET=change-me-to-a-very-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

## Registration
REGISTRATION_OPEN=true

## Whitelist (optional)
# Enable to restrict registration to specific usernames only.
# Edit whitelist.txt and add allowed usernames (one per line).
# WHITELIST_ENABLED=true
# WHITELIST_FILE=whitelist.txt

## Domain (required for HTTPS via Let's Encrypt)
# Set your domain here, Caddy will auto-provision SSL:
DOMAIN=budak.example.com

## TLS with custom certificates (optional)
# If you have your own certs, place them in ./certs/ and uncomment:
# BUDAK_CERTS_DIR=./certs
# TLS_CERT_PATH=/certs/cert.pem
# TLS_KEY_PATH=/certs/key.pem

## Cloudflare Tunnel (optional alternative to direct HTTPS)
# Uncomment tunnel service in docker-compose.yml first, then:
# CLOUDFLARE_TUNNEL_TOKEN=

## Docker image version
BUDAK_VERSION=latest
