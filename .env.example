# Budak — Single Binary Configuration
# Copy this to .env in the same directory as the binary.

## Database
DB_URL=postgres://budak:budak@localhost:5432/budak

## JWT (generate with: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-very-long-random-string

## Server
PORT=8080

## Registration
REGISTRATION_OPEN=true

## Whitelist (optional)
# Restrict registration to specific usernames.
# Create whitelist.txt (one username per line) next to the binary.
# WHITELIST_ENABLED=true
