# Budak — Production Configuration
# Copy this file to .env and fill in your values

## Database
DB_USER=budak
DB_PASSWORD=generate-a-strong-password
DB_NAME=budak

## JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET

## Registration
REGISTRATION_OPEN=true

## Whitelist (optional)
# Enable to restrict registration to specific usernames only.
# Edit whitelist.txt and add allowed usernames (one per line).
# WHITELIST_ENABLED=true
# WHITELIST_FILE=whitelist.txt

## Domain
DOMAIN=budak.yourdomain.com

## Docker image version
BUDAK_VERSION=latest

## TLS certificates
BUDAK_CERTS_DIR=./certs
TLS_CERT_PATH=
TLS_KEY_PATH=
