# Tudo — Production Configuration
# Copy this file to .env and fill in your values

## Database
DB_USER=tudo
DB_PASSWORD=generate-a-strong-password
DB_NAME=tudo

## JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET

## Registration (set to false after creating your account)
REGISTRATION_OPEN=true

## Domain (used by Caddy for Let's Encrypt)
DOMAIN=tudo.yourdomain.com

## Docker image version (e.g., v1.0.0)
TUDO_VERSION=latest

## TLS certificates (directory on host)
## If using Let's Encrypt (auto), leave empty
TUDO_CERTS_DIR=./certs
TLS_CERT_PATH=
TLS_KEY_PATH=
