# Tudo Caddyfile
# If you have your own certificates, place them in the certs/ directory
# and set TLS_CERT_PATH and TLS_KEY_PATH environment variables.
# Otherwise, Caddy will use Let's Encrypt automatically.

{$DOMAIN:-localhost} {
    # TLS with optional manual cert
    tls {$TLS_CERT_PATH:-} {$TLS_KEY_PATH:-}

    # Frontend (static files)
    handle_path /api/* {
        reverse_proxy backend:8080
    }

    # Frontend (SPA)
    handle {
        reverse_proxy frontend:80
    }
}
